# =====================================================
# Bloomly iOS - .gitignore
# Protects: API keys, build artifacts, sensitive data
# =====================================================


# =====================================================
# đź”’ CRITICAL: Sensitive Files (NEVER COMMIT)
# =====================================================

# API Keys & Configuration
Config.plist
Config-*.plist
Secrets.plist
*.xcconfig
.env
.env.local
.env.development
.env.production

# Certificates & Provisioning
*.p12
*.cer
*.certSigningRequest
*.mobileprovision
*.provisionprofile

# Service Account Keys
GoogleService-Info.plist
google-services.json
service-account.json
firebase-adminsdk-*.json

# RevenueCat / Analytics
revenuecat-config.json
mixpanel-token.txt
sentry.properties
sentry-dsn.txt


# =====================================================
# đźŤŽ Xcode
# =====================================================

# Build products
build/
DerivedData/
*.app
*.ipa
*.dSYM
*.dSYM.zip

# User data (personal Xcode settings)
xcuserdata/
*.xcuserstate
*.xcuserdatad/
project.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Workspace state
*.xcscmblueprint
*.xccheckout

# Xcode patch files
*.moved-aside

# Xcode crash logs
crashlytics-build.properties
crashlytics.properties


# =====================================================
# đź“¦ Swift Package Manager
# =====================================================

.swiftpm/
Package.resolved
.build/
.package.resolved


# =====================================================
# đźŤŞ CocoaPods (in case used later)
