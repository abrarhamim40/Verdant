# =====================================================

*.pem
*.key
id_rsa*
id_ed25519*


# =====================================================
# đź“ť Notes & Drafts
# =====================================================

# Personal notes (don't commit ideas/passwords/etc.)
notes.md
TODO-personal.md
SCRATCH.md
draft-*.md

# But keep important docs
!README.md
!MASTER_PLAN.md
!CLAUDE.md
!SETUP_CHECKLIST.md
!.claude/PROMPTS.md
!.claude/tracking/PROGRESS.md


# =====================================================
# đźŽ¬ Misc
# =====================================================

# Compressed files (usually exports/builds)
*.zip
*.tar.gz
*.rar
*.7z

# But keep important ones if needed
!docs/*.zip


# =====================================================
# âš ď¸Ź FINAL CHECKLIST BEFORE COMMIT:
# âś… No API keys in any .swift file
# âś… Config.plist exists locally but NOT in git
# âś… No GoogleService-Info.plist committed
# âś… No certificates or provisioning profiles
# âś… No .env files
# =====================================================

# Claude Code local settings (per-user, do not commit)
.claude/settings.local.json

# graphify knowledge graph output (regenerable, large)
graphify-out/
