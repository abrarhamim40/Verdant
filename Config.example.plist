<?xml version="1.0" encoding="UTF-8"?>
<!--
=====================================================
Bloomly - Config.plist TEMPLATE
=====================================================

⚠️ IMPORTANT INSTRUCTIONS:

1. Copy this file → rename to "Config.plist"
2. Replace YOUR_*_HERE placeholders with real API keys
3. Add to your Xcode project (drag into Resources/)
4. NEVER commit Config.plist to git (.gitignore handles this)

How to get keys:
- Plant.id: https://web.plant.id → Dashboard → API Keys
- Gemini: https://aistudio.google.com → Get API Key
- RevenueCat: https://app.revenuecat.com → Project Settings

=====================================================
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ⭐ Plant.id API - REQUIRED -->
    <key>PLANT_ID_API_KEY</key>
    <string>YOUR_PLANT_ID_KEY_HERE</string>
    
    <!-- ⭐ Gemini API - REQUIRED -->
    <key>GEMINI_API_KEY</key>
    <string>YOUR_GEMINI_KEY_HERE</string>
    
    <!-- 💰 RevenueCat - Required from Week 6 -->
    <key>REVENUECAT_API_KEY</key>
    <string>YOUR_REVENUECAT_KEY_HERE</string>
    
    <!-- 📊 Optional Analytics (add Week 7) -->
    <key>POSTHOG_API_KEY</key>
    <string></string>
    
    <!-- 🐛 Optional Crash Reporting (add Week 7) -->
    <key>SENTRY_DSN</key>
    <string></string>
    
    <!-- 🌍 Environment Flag -->
    <key>ENVIRONMENT</key>
    <string>development</string>
    <!-- Values: development | staging | production -->
</dict>
</plist>
